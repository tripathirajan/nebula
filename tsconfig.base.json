{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "allowJs": false,
    "types": ["node", "@testing-library/jest-dom", "vitest-axe/extend-expect"],
    "paths": {
      "@nebula-lab/headless": ["./packages/headless/src/index.ts"],
      "@nebula-lab/headless/*": ["./packages/headless/src/*"],
      "@nebula-lab/hooks": ["./packages/hooks/src/index.ts"],
      "@nebula-lab/hooks/*": ["./packages/hooks/src/*"],
      "@nebula-lab/primitives": ["./packages/primitives/src/index.ts"],
      "@nebula-lab/primitives/*": ["./packages/primitives/src/*"],
      "@nebula-lab/react-ui": ["./packages/react-ui/src/index.ts"],
      "@nebula-lab/react-ui-blocks": ["./packages/react-ui-blocks/src/index.ts"],
      "@nebula-lab/react-ui-blocks/*": ["./packages/react-ui-blocks/src/*"],
      "@nebula-lab/react-ui/*": ["./packages/react-ui/src/*"],
      "@nebula-lab/styleless": ["./packages/styleless/src/index.ts"],
      "@nebula-lab/styleless/*": ["./packages/styleless/src/*"],
      "@nebula-lab/utilities": ["./packages/utilities/src/index.ts"],
      "@nebula-lab/utilities/*": ["./packages/utilities/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "storybook-static"]
}
