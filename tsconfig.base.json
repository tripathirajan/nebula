{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": false,
    "incremental": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true,
    "allowJs": false,
    // Explicit list, not "include everything in node_modules/@types" ‚Äî but
    // that means every ambient global the codebase actually relies on (e.g.
    // `process` in tokens/generate.ts and contrast-audit.ts) must be listed
    // here too, not just the test-matcher packages this was added for.
    //
    // NOTE: this does NOT cover the `vitest-axe` ‚Üí Vitest 2.x `Assertion`
    // typing gap (`toHaveNoViolations` not recognized by `tsc`) ‚Äî adding a
    // package-name `types` entry only works for things resolvable as a real
    // node_modules package, and there's no such package for a hand-written
    // ambient fix. That's instead fixed per-package via a checked-in
    // `src/vitest-axe-matchers.d.ts` (see any test file using
    // `toHaveNoViolations` ‚Äî `primitives`, `headless`, `react-ui`) picked
    // up automatically by each package's own `"include": ["src"]`.
    "types": [
      "node",
      "@testing-library/jest-dom",
      "vitest-axe/extend-expect"
    ],
    // No `baseUrl` here by design (Bundler resolution shouldn't need one) ‚Äî
    // but TS 5.x's stricter `paths` validation (TS5090) requires every path
    // value to look explicitly relative when `baseUrl` is absent, or it
    // rejects the config outright. These were always intended to resolve
    // relative to *this* file's directory (the repo root) ‚Äî the leading
    // "./" makes that explicit instead of implicit; it doesn't change where
    // anything actually resolves to.
    "paths": {
      // Add an entry here each time a new packages/* is scaffolded.
      "@nebula-lab/utilities": [
        "./packages/utilities/src/index.ts"
      ],
      "@nebula-lab/utilities/*": [
        "./packages/utilities/src/*"
      ],
      "@nebula-lab/hooks": [
        "./packages/hooks/src/index.ts"
      ],
      "@nebula-lab/hooks/*": [
        "./packages/hooks/src/*"
      ],
      "@nebula-lab/primitives": [
        "./packages/primitives/src/index.ts"
      ],
      "@nebula-lab/primitives/*": [
        "./packages/primitives/src/*"
      ],
      "@nebula-lab/headless": [
        "./packages/headless/src/index.ts"
      ],
      "@nebula-lab/headless/*": [
        "./packages/headless/src/*"
      ],
      "@nebula-lab/styleless": [
        "./packages/styleless/src/index.ts"
      ],
      "@nebula-lab/styleless/*": [
        "./packages/styleless/src/*"
      ],
      "@nebula-lab/react-ui": [
        "./packages/react-ui/src/index.ts"
      ],
      "@nebula-lab/react-ui/*": [
        "./packages/react-ui/src/*"
      ],
      "@nebula-lab/react-ui-blocks": [
        "./packages/react-ui-blocks/src/index.ts"
      ],
      "@nebula-lab/react-ui-blocks/*": [
        "./packages/react-ui-blocks/src/*"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "storybook-static"
  ]
}