{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "sharedGlobals": [],
    "production": [
      "default",
      "!{projectRoot}/**/*.stories.tsx",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/**/*.test.tsx",
      "!{projectRoot}/.storybook/**/*"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "outputs": [
        "{projectRoot}/dist"
      ],
      "cache": true
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "lint": {
      "inputs": [
        "default",
        "{workspaceRoot}/eslint.config.mjs"
      ],
      "cache": true
    },
    "test": {
      "inputs": [
        "default",
        "{workspaceRoot}/vitest.config.ts",
        "{workspaceRoot}/vitest.setup.ts"
      ],
      "cache": true
    },
    "dev": {
      "cache": false
    }
  },
  "release": {
    "projectsRelationship": "independent"
  },
  "plugins": [
    {
      "plugin": "@nx/js/typescript",
      "options": {
        "typecheck": {
          "targetName": "typecheck"
        },
        "build": {
          "targetName": "build-base",
          "configName": "tsconfig.lib.json"
        }
      }
    }
  ],
  "nxCloudId": "6a4e8bcb8500bc9aa4a9ec69"
}