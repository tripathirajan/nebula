{
  "name": "@nebula/styleless",
  "version": "0.1.0",
  "description": "Behavior-only, ARIA-complete compound components — no styling opinions (formerly @nebula/headless; renamed since \"styleless\" says directly what this layer guarantees). Built on @nebula/primitives + @nebula/hooks; styled by @nebula/react-ui.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js",
      "require": "./dist/tabs/index.cjs"
    },
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js",
      "require": "./dist/checkbox/index.cjs"
    },
    "./switch": {
      "types": "./dist/switch/index.d.ts",
      "import": "./dist/switch/index.js",
      "require": "./dist/switch/index.cjs"
    },
    "./radio-group": {
      "types": "./dist/radio-group/index.d.ts",
      "import": "./dist/radio-group/index.js",
      "require": "./dist/radio-group/index.cjs"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "import": "./dist/accordion/index.js",
      "require": "./dist/accordion/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --root ../.. packages/styleless",
    "test:watch": "vitest --root ../.. packages/styleless"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@nebula/hooks": "workspace:*",
    "@nebula/primitives": "workspace:*"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}