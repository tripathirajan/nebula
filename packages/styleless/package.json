{
  "name": "@nebula/styleless",
  "version": "0.1.0",
  "description": "Reusable UI components with a complete, semantic API but zero visual opinion — composes @nebula/primitives + @nebula/headless. Styled by @nebula/react-ui. See LAYER_TAXONOMY.md for the full component list this package extracts from react-ui.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./icon-button": {
      "types": "./dist/icon-button/index.d.ts",
      "import": "./dist/icon-button/index.js"
    },
    "./fab": {
      "types": "./dist/fab/index.d.ts",
      "import": "./dist/fab/index.js"
    },
    "./split-button": {
      "types": "./dist/split-button/index.d.ts",
      "import": "./dist/split-button/index.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./textarea": {
      "types": "./dist/textarea/index.d.ts",
      "import": "./dist/textarea/index.js"
    },
    "./password-input": {
      "types": "./dist/password-input/index.d.ts",
      "import": "./dist/password-input/index.js"
    },
    "./search-input": {
      "types": "./dist/search-input/index.d.ts",
      "import": "./dist/search-input/index.js"
    },
    "./email-input": {
      "types": "./dist/email-input/index.d.ts",
      "import": "./dist/email-input/index.js"
    },
    "./url-input": {
      "types": "./dist/url-input/index.d.ts",
      "import": "./dist/url-input/index.js"
    },
    "./tel-input": {
      "types": "./dist/tel-input/index.d.ts",
      "import": "./dist/tel-input/index.js"
    },
    "./image-preview": {
      "types": "./dist/image-preview/index.d.ts",
      "import": "./dist/image-preview/index.js"
    },
    "./avatar": {
      "types": "./dist/avatar/index.d.ts",
      "import": "./dist/avatar/index.js"
    },
    "./avatar-group": {
      "types": "./dist/avatar-group/index.d.ts",
      "import": "./dist/avatar-group/index.js"
    },
    "./code-block": {
      "types": "./dist/code-block/index.d.ts",
      "import": "./dist/code-block/index.js"
    },
    "./data-table": {
      "types": "./dist/data-table/index.d.ts",
      "import": "./dist/data-table/index.js"
    },
    "./data-grid": {
      "types": "./dist/data-grid/index.d.ts",
      "import": "./dist/data-grid/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --root ../.. packages/styleless",
    "test:watch": "vitest --root ../.. packages/styleless"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nebula/headless": "workspace:*",
    "@nebula/hooks": "workspace:*",
    "@nebula/primitives": "workspace:*"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
