{
  "name": "@nebula/utilities",
  "version": "0.1.0",
  "description": "Framework-agnostic helpers with zero React dependency — the bottom of the nebula dependency graph. Everything else may depend on this; this depends on nothing in the workspace.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./clamp": {
      "types": "./dist/clamp/index.d.ts",
      "import": "./dist/clamp/index.js",
      "require": "./dist/clamp/index.cjs"
    },
    "./debounce": {
      "types": "./dist/debounce/index.d.ts",
      "import": "./dist/debounce/index.js",
      "require": "./dist/debounce/index.cjs"
    },
    "./throttle": {
      "types": "./dist/throttle/index.d.ts",
      "import": "./dist/throttle/index.js",
      "require": "./dist/throttle/index.cjs"
    },
    "./deep-merge": {
      "types": "./dist/deep-merge/index.d.ts",
      "import": "./dist/deep-merge/index.js",
      "require": "./dist/deep-merge/index.cjs"
    },
    "./is-html-element": {
      "types": "./dist/is-html-element/index.d.ts",
      "import": "./dist/is-html-element/index.js",
      "require": "./dist/is-html-element/index.cjs"
    },
    "./is-focusable": {
      "types": "./dist/is-focusable/index.d.ts",
      "import": "./dist/is-focusable/index.js",
      "require": "./dist/is-focusable/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
