      "require": "./dist/use-click-outside/index.cjs"
    },
    "./use-media-query": {
      "types": "./dist/use-media-query/index.d.ts",
      "import": "./dist/use-media-query/index.js",
      "require": "./dist/use-media-query/index.cjs"
    },
    "./use-scroll-lock": {
      "types": "./dist/use-scroll-lock/index.d.ts",
      "import": "./dist/use-scroll-lock/index.js",
      "require": "./dist/use-scroll-lock/index.cjs"
    },
