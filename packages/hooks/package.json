    },
    "./use-mutation-observer": {
      "types": "./dist/use-mutation-observer/index.d.ts",
      "import": "./dist/use-mutation-observer/index.js",
      "require": "./dist/use-mutation-observer/index.cjs"
    },
    "./use-local-storage": {
      "types": "./dist/use-local-storage/index.d.ts",
      "import": "./dist/use-local-storage/index.js",
      "require": "./dist/use-local-storage/index.cjs"
