{
  "name": "@nebula/react-ui",
  "version": "0.1.0",
  "description": "Tailwind-powered styled components (atoms) built on @nebula/primitives + @nebula/styleless, plus the 3-layer design token system and ThemeProvider/useTheme they're styled from. Absorbed the former @nebula/theme package — nothing else in the workspace needs tokens/theming, only this package's own components do.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./input": {
      "types": "./dist/input/index.d.ts",
      "import": "./dist/input/index.js"
    },
    "./card": {
      "types": "./dist/card/index.d.ts",
      "import": "./dist/card/index.js"
    },
    "./badge": {
      "types": "./dist/badge/index.d.ts",
      "import": "./dist/badge/index.js"
    },
    "./avatar": {
      "types": "./dist/avatar/index.d.ts",
      "import": "./dist/avatar/index.js"
    },
    "./separator": {
      "types": "./dist/separator/index.d.ts",
      "import": "./dist/separator/index.js"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "import": "./dist/accordion/index.js"
    },
    "./dialog": {
      "types": "./dist/dialog/index.d.ts",
      "import": "./dist/dialog/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js"
    },
    "./tooltip": {
      "types": "./dist/tooltip/index.d.ts",
      "import": "./dist/tooltip/index.js"
    },
    "./tabs": {
      "types": "./dist/tabs/index.d.ts",
      "import": "./dist/tabs/index.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js"
    },
    "./switch": {
      "types": "./dist/switch/index.d.ts",
      "import": "./dist/switch/index.js"
    },
    "./radio-group": {
      "types": "./dist/radio-group/index.d.ts",
      "import": "./dist/radio-group/index.js"
    },
    "./progress": {
      "types": "./dist/progress/index.d.ts",
      "import": "./dist/progress/index.js"
    },
    "./spinner": {
      "types": "./dist/spinner/index.d.ts",
      "import": "./dist/spinner/index.js"
    },
    "./skeleton": {
      "types": "./dist/skeleton/index.d.ts",
      "import": "./dist/skeleton/index.js"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    },
    "./theme-provider": {
      "types": "./dist/theme-provider/index.d.ts",
      "import": "./dist/theme-provider/index.js"
    },
    "./theme.css": "./src/theme.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src/theme.css"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo && tsx src/tokens/generate.ts && cp src/theme.css dist/theme.css",
    "dev": "tsup --watch",
    "generate-tokens": "tsx src/tokens/generate.ts",
    "contrast-audit": "tsx src/tokens/contrast-audit.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --root ../.. packages/react-ui",
    "test:watch": "vitest --root ../.. packages/react-ui"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nebula/hooks": "workspace:*",
    "@nebula/primitives": "workspace:*",
    "@nebula/styleless": "workspace:*",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
