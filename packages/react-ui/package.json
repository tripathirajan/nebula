  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo && tsx src/tokens/generate.ts && cp src/theme.css dist/theme.css",
    "dev": "tsup --watch",
    "generate-tokens": "tsx src/tokens/generate.ts",
    "contrast-audit": "tsx src/tokens/contrast-audit.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --root ../.. packages/react-ui",
    "test:watch": "vitest --root ../.. packages/react-ui"
  },
