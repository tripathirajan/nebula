{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // See packages/headless/tsconfig.typecheck.json for why `paths` is
    // cleared here — same rootDir violation (TS6059/TS6307) that
    // tsconfig.build.json already works around for the build pass, applied
    // to typecheck too. Safe because nx.json's `typecheck: { dependsOn:
    // ['^build'] }` guarantees this package's dependencies are already built
    // (and therefore resolvable via node_modules) before this ever runs for
    // real.
    "paths": {}
  },
  "exclude": ["dist"]
}
