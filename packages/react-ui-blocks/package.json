{
  "name": "@nebula/react-ui-blocks",
  "version": "0.1.0",
  "description": "Ready-to-use, domain-neutral screens and composite blocks (theme switchers, page shells, forms, dashboards, auth flows, ...) built purely from @nebula/react-ui (which owns both the styled components and the token/theme system). The top of the dependency graph — nothing else in this repo depends on it.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme-switcher": {
      "types": "./dist/theme-switcher/index.d.ts",
      "import": "./dist/theme-switcher/index.js"
    },
    "./app-layout": {
      "types": "./dist/app-layout/index.d.ts",
      "import": "./dist/app-layout/index.js"
    },
    "./login-form": {
      "types": "./dist/login-form/index.d.ts",
      "import": "./dist/login-form/index.js"
    },
    "./transaction-form": {
      "types": "./dist/transaction-form/index.d.ts",
      "import": "./dist/transaction-form/index.js"
    },
    "./dashboard-layout": {
      "types": "./dist/dashboard-layout/index.d.ts",
      "import": "./dist/dashboard-layout/index.js"
    },
    "./auth-layout": {
      "types": "./dist/auth-layout/index.d.ts",
      "import": "./dist/auth-layout/index.js"
    },
    "./settings-layout": {
      "types": "./dist/settings-layout/index.d.ts",
      "import": "./dist/settings-layout/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nebula/primitives": "workspace:*",
    "@nebula/react-ui": "workspace:*"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
