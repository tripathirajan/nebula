{
  "name": "@nebula-lab/react-ui-blocks",
  "version": "0.1.4-beta.1",
  "description": "Ready-to-use, domain-neutral screens and composite blocks (theme switchers, page shells, forms, dashboards, auth flows, ...) built purely from @nebula-lab/react-ui (which owns both the styled components and the token/theme system). The top of the dependency graph — nothing else in this repo depends on it.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "Rajan Tripathi <tripathirajan3@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tripathirajan/nebula.git",
    "directory": "packages/react-ui-blocks"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./authentication": {
      "types": "./dist/authentication/index.d.ts",
      "import": "./dist/authentication/index.js"
    },
    "./marketing": {
      "types": "./dist/marketing/index.d.ts",
      "import": "./dist/marketing/index.js"
    },
    "./ecommerce": {
      "types": "./dist/ecommerce/index.d.ts",
      "import": "./dist/ecommerce/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js"
    },
    "./communication": {
      "types": "./dist/communication/index.d.ts",
      "import": "./dist/communication/index.js"
    },
    "./social": {
      "types": "./dist/social/index.d.ts",
      "import": "./dist/social/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly && rm -f dist/*.tsbuildinfo",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --root ../.. packages/react-ui-blocks",
    "test:watch": "vitest --root ../.. packages/react-ui-blocks"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nebula-lab/hooks": "workspace:*",
    "@nebula-lab/primitives": "workspace:*",
    "@nebula-lab/react-ui": "workspace:*",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
